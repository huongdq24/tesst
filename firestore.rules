
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chỉ cho phép người dùng đăng nhập truy cập dữ liệu của chính họ
    match /users/{userId} {
      allow get, write: if request.auth != null && request.auth.uid == userId;
      
      // Cho phép quản lý các dự án con (ảnh/video)
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Rule dự phòng cho quản trị viên (nếu cần)
    match /roles_admin/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
