rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * iGen Ecosystem Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust, path-based ownership model complemented by Database-Backed 
     * Access Control (DBAC) for administrative roles. Security is enforced primarily through 
     * user-specific subcollections and document path wildcards.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document exists and the current user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * Checks if the current user has administrative privileges.
     * Logic: Existence in /admins OR matching the specific super-admin email.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "igen-architect@admin.com"
      );
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Rules for AI projects belonging to a specific user.
       */
      match /projects/{projectId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Global AI features registry.
     */
    match /features/{featureId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Registry for administrative users.
     */
    match /admins/{adminId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}