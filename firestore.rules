rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * iGen AI Assistant Security Rules - Optimized
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Kiểm tra Admin hệ thống qua Email.
     */
    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'igen-architect@admin.com' ||
        request.auth.token.email == 'igentech1@gmail.com'
      );
    }

    /** 
     * @description Kiểm tra Admin tổng hợp.
     * Sử dụng đoản mạch (short-circuit) để tránh exists() nếu đã là System Admin.
     */
    function isAdmin() {
      return isSystemAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    match /roles_admin/{adminId} {
      // Cho phép người dùng tự kiểm tra trạng thái admin của mình (phục vụ hàm exists)
      allow get: if isSignedIn() && request.auth.uid == adminId;
      // Chỉ Admin hệ thống mới có quyền quản lý danh sách Admin
      allow read, write: if isSystemAdmin();
    }

    match /users/{userId} {
      // Quyền trên tài liệu User
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && isUnchanged('id');
      allow delete: if isAdmin();

      match /projects/{projectId} {
        // Quyền trên các dự án thuộc User
        // read = get + list. Cho phép chủ sở hữu hoặc admin.
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isOwner(userId) || isAdmin()) && isUnchanged('userId');
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}