rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * iGen AI Assistant Security Rules - Optimized for Admin & Owner access
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Kiểm tra Admin hệ thống qua Email hardcoded.
     */
    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'igen-architect@admin.com' ||
        request.auth.token.email == 'igentech1@gmail.com'
      );
    }

    /** 
     * @description Kiểm tra Admin tổng hợp.
     * Tối ưu hóa thứ tự để tránh gọi exists() không cần thiết trong các truy vấn list.
     */
    function isAdmin() {
      return isSystemAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    match /roles_admin/{adminId} {
      // Cho phép người dùng tự kiểm tra trạng thái admin của mình (phục vụ hàm exists)
      allow get: if isSignedIn() && (request.auth.uid == adminId || isSystemAdmin());
      // Chỉ Admin hệ thống mới có quyền quản lý danh sách Admin
      allow read, write: if isSystemAdmin();
    }

    match /users/{userId} {
      // Quyền trên tài liệu User
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && (
        !('id' in request.resource.data) || request.resource.data.id == resource.data.id
      );
      allow delete: if isAdmin();

      match /projects/{projectId} {
        // Quyền trên các dự án thuộc User. 
        // Ưu tiên isOwner để Firestore Rules Engine phê duyệt nhanh các truy vấn list/get của chính chủ.
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Chặn tất cả các truy cập khác mặc định
    match /{path=**} {
      allow read, write: if false;
    }
  }
}