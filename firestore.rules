rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * iGen AI Assistant Security Rules - Optimized for Master Sync
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Kiểm tra Admin. 
     * Ưu tiên kiểm tra Email hệ thống trước để tối ưu hiệu suất và tránh lỗi circularity.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'igen-architect@admin.com' ||
        request.auth.token.email == 'igentech1@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    match /roles_admin/{adminId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // Người dùng có thể xem profile của chính mình, Admin có thể xem tất cả
      allow get: if isOwner(userId) || isAdmin();
      // Chỉ Admin mới có thể liệt kê tất cả người dùng
      allow list: if isAdmin();
      // Cho phép tạo profile mới nếu UID khớp
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Cho phép cập nhật nếu là chủ sở hữu hoặc admin, không được đổi ID
      allow update: if (isOwner(userId) || isAdmin()) && isUnchanged('id');
      // Chỉ Admin mới có quyền xóa người dùng
      allow delete: if isAdmin();

      match /projects/{projectId} {
        // Chủ sở hữu dự án hoặc Admin có quyền xem/liệt kê
        allow read: if isOwner(userId) || isAdmin();
        // Chỉ chủ sở hữu mới có thể tạo dự án gắn với ID của mình
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        // Chủ sở hữu hoặc Admin có quyền cập nhật, không được đổi userId
        allow update: if (isOwner(userId) || isAdmin()) && isUnchanged('userId');
        // Chủ sở hữu hoặc Admin có quyền xóa dự án
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}