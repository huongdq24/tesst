
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Thông tin hồ sơ người dùng, vai trò và trạng thái kích hoạt iGen credits.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "hasClaimedCredits": { "type": "boolean" },
        "apiKey": { "type": "string", "description": "API Key Tier 1 đã liên kết" },
        "preferredLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "hasClaimedCredits", "createdAt", "updatedAt"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Lưu trữ lịch sử ảnh/video đã tạo. Hệ thống sẽ tự động xóa tài liệu này sau 30 ngày dựa trên trường createdAt (TTL Policy).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "featureId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "outputUrl": { "type": "string" },
        "mode": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Trường mốc thời gian để Firestore thực hiện xóa tự động (TTL)" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "featureId", "outputUrl", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Hồ sơ người dùng riêng tư."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Lịch sử dự án cá nhân, tự động xóa sau 30 ngày thông qua chính sách TTL trên trường createdAt."
    }
  }
}
