
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the iGen application, storing their profile information and application-specific settings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID) for the User."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "User role (admin/user)."
        },
        "hasClaimedCredits": {
          "type": "boolean",
          "description": "Whether the user has claimed initial credits."
        },
        "apiKey": {
          "type": "string",
          "description": "User-provided API key for AI services."
        },
        "credits": {
          "type": "string",
          "description": "Current available credits balance synchronized from Google Cloud Billing."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role"
      ]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents an AI-generated output (video/image) stored for a user. TTL policy of 30 days applies to this entity.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "featureId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "outputUrl": {
          "type": "string",
          "format": "uri"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "TIMESTAMP FIELD FOR TTL POLICY (30 DAYS)."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "User project history. Automatically cleared after 30 days via Cloud Console TTL policy on 'createdAt' field. Note: Requires project-5306ce34-5626-488a-913 to have a Firestore database in Native Mode."
    }
  }
}
